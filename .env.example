# SnapCut — Environment Variables Reference
# Copy config.js and replace the values with your actual keys.
# For a backend/server setup, use these as environment variables instead.

# Razorpay (https://dashboard.razorpay.com)
# Test keys start with rzp_test_ and never charge real money
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=YOUR_KEY_SECRET_HERE
